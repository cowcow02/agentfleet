{
  "name": "@agentfleet/db",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "push": "drizzle-kit push",
    "db:reset": "psql -d postgres -c 'DROP DATABASE IF EXISTS agentfleet_e2e;' && psql -d postgres -c 'CREATE DATABASE agentfleet_e2e;' && drizzle-kit migrate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.41",
    "pg": "^8.20"
  },
  "devDependencies": {
    "drizzle-kit": "^0.30",
    "@types/pg": "^8",
    "typescript": "^5.7"
  }
}
